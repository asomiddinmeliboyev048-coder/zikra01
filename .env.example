# ============================================
# Zikra — Muhit o'zgaruvchilari (Environment variables)
# Ushbu faylni .env.local nomi bilan nusxalang va qiymatlarni to'ldiring.
# ============================================

# --- Supabase ---
# Supabase loyiha sozlamalari -> API bo'limidan oling
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (service role) — faqat server tomonda ishlatiladi, MAXFIY!
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Rasm/Video yuklash ---
# Cloudinary KERAK EMAS! Endi rasm va video Supabase Storage'ga yuklanadi.
# Faqat supabase/storage-setup.sql ni SQL Editor'da ishga tushiring.

# --- AWS S3 (reels / qisqa videolar) ---
# MUHIM: Bu kalitlar FAQAT server tomonda ishlatiladi. Ular oldiga
# NEXT_PUBLIC_ QO'YMANG — aks holda brauzerga tushib, oshkor bo'ladi.
# Kalitlarni IAM foydalanuvchisiga bering (root emas), faqat s3:PutObject
# ruxsati bilan. Bu qiymatlarni GIT'ga commit QILMANG (.env.local ishlating).
AWS_REGION=eu-central-1
AWS_S3_BUCKET=zikra-video-storage-2026
AWS_ACCESS_KEY_ID=YOUR_NEW_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_NEW_SECRET_KEY
# Videolarni ommaviy o'qish uchun asosiy URL (bucket public-read bo'lsa):
# https://<bucket>.s3.<region>.amazonaws.com
# Kelajakda CloudFront qo'shsangiz — shu qiymatni CloudFront domeniga almashtiring.
S3_PUBLIC_BASE_URL=https://zikra-video-storage-2026.s3.eu-central-1.amazonaws.com

# --- Sayt manzili (auth redirect uchun) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# --- Firebase Cloud Messaging (FCM) — Push bildirishnomalar (ixtiyoriy) ---
# Firebase Console > Project Settings > General > Web app config'dan oling.
# Bo'sh qoldirilsa — push o'chiq bo'ladi (ilova baribir ishlaydi).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Cloud Messaging > Web Push certificates > Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- send-push Edge Function uchun (Supabase secrets sifatida o'rnating) ---
# FIREBASE_CLIENT_EMAIL=...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"


# --- TURN server (video/ovozli qo'ng'iroq turli tarmoqlar — 4G↔4G — orasida ishlashi uchun) ---
# ENG ISHONCHLI: Metered API orqali (to'g'ri host + yangi credential avtomatik).
# Metered Dashboard > TURN Server > "Show API Key" dan API key oling.
NEXT_PUBLIC_METERED_APP=zikra
NEXT_PUBLIC_METERED_API_KEY=

# Zaxira (API ishlamasa) — statik username/credential:
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
NEXT_PUBLIC_TURN_HOST=
NEXT_PUBLIC_TURN_URL=
