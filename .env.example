# ============================================
# Zikra — Muhit o'zgaruvchilari (Environment variables)
# Ushbu faylni .env.local nomi bilan nusxalang va qiymatlarni to'ldiring.
# ============================================

# --- Supabase ---
# Supabase loyiha sozlamalari -> API bo'limidan oling
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (service role) — faqat server tomonda ishlatiladi, MAXFIY!
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Cloudinary (video yuklash uchun, bepul tier) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR-CLOUD-NAME
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=zikra_unsigned

# --- Sayt manzili (auth redirect uchun) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
